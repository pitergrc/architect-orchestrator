            "title": "Text"
          },
          "priority": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "title": "Priority",
            "default": "medium"
          },
          "droppable": {
            "type": "boolean",
            "title": "Droppable",
            "default": false
